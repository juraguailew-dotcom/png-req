# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API

# Your project URL (e.g. https://xxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon/public key — safe to expose in browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role / secret key — NEVER expose to browser
# New format: sb_secret_... (works for DB but not auth.admin API)
# Old format: eyJ...      (works for everything including auth.admin API)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_... or eyJ...

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get a free API key from https://resend.com
# Leave blank to skip email sending (registration still works)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ─── App URL ─────────────────────────────────────────────────────────────────
# Used in welcome email links — set to your Vercel deployment URL in production
NEXT_PUBLIC_APP_URL=http://localhost:3000
